# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Server
PORT=5000
NODE_ENV=development

# Database — your LOCAL PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/HRMS_database?schema=public"

# JWT
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="24h"

# Email (Nodemailer) — use a Gmail App Password, NOT your account password
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-gmail-app-password"

# Frontend URL
CLIENT_URL="http://localhost:3000/"
